# Garage configuration — generated by run.sh from Home Assistant add-on options.
# Do NOT edit this file directly; changes will be overwritten on restart.
# Adjust settings through the add-on configuration panel instead.

# ─── Storage paths ───────────────────────────────────────────────────────────
# metadata_dir: indexes, node state — benefits from fast storage (SSD)
metadata_dir = "@@META_DIR@@"
# data_dir: actual object blocks — HDDs are fine here
data_dir     = "@@DATA_DIR@@"

# ─── Database engine ─────────────────────────────────────────────────────────
# lmdb is recommended for single-node setups
db_engine = "lmdb"

# ─── Block and replication ───────────────────────────────────────────────────
block_size         = "1M"
replication_factor = 1        # single-node: no replication

# ─── Compression ─────────────────────────────────────────────────────────────
@@COMPRESSION_LINE@@

# ─── RPC (cluster communication) ─────────────────────────────────────────────
rpc_bind_addr   = "[::]:3901"
rpc_public_addr = "127.0.0.1:3901"
rpc_secret      = "@@RPC_SECRET@@"

# ─── S3 API ──────────────────────────────────────────────────────────────────
[s3_api]
s3_region    = "@@S3_REGION@@"
api_bind_addr = "[::]:@@S3_PORT@@"
# root_domain enables virtual-hosted–style bucket URLs:
#   e.g. mybucket.s3.garage → if DNS is configured
root_domain  = ".s3.garage"

# ─── S3 static website hosting ───────────────────────────────────────────────
[s3_web]
bind_addr   = "[::]:3902"
root_domain = ".web.garage"
index       = "index.html"

# ─── Admin API ───────────────────────────────────────────────────────────────
# Bound to loopback only — not exposed outside the container.
[admin]
api_bind_addr = "127.0.0.1:@@ADMIN_PORT@@"
admin_token   = "@@ADMIN_TOKEN@@"
