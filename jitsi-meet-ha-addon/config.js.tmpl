// Jitsi Meet web config.js template
// Generated from /data/options.json by run.sh

var config = {
    hosts: {
        domain: '${XMPP_DOMAIN}',
        muc: 'conference.${XMPP_DOMAIN}',
        focus: 'focus.${XMPP_DOMAIN}',
    },

    bosh: '//${XMPP_DOMAIN}/http-bind',
    // websocket disabled: lib-jitsi-meet tries WebSocket first and does not
    // reliably fall back when the WS upgrade fails (code 1006). BOSH is
    // confirmed working and is sufficient. Re-enable once WS is debugged.
    // websocket: 'wss://${XMPP_DOMAIN}/xmpp-websocket',

    // Peer-to-peer disabled (use JVB for all calls)
    p2p: {
        enabled: false,
    },

    // Recording (Jibri) — enabled only if configured
    fileRecordingsEnabled: ${RECORDING_ENABLED},
    liveStreamingEnabled: false,

    // Default room name shown in welcome page
    defaultRoomName: '${DEFAULT_ROOM}',

    // Use a numeric room name generator instead of CamelCaseWords.
    // CamelCase patterns (e.g. FrustratingReasonsHarvestEfficiently) trigger
    // Chrome's Safe Browsing heuristics and cause a "Dangerous site" warning.
    generateRoomnames: false,

    // Start muted options
    startAudioMuted: 9,
    startVideoMuted: 9,

    // Resolution
    resolution: 720,
    constraints: {
        video: {
            height: { ideal: 720, max: 1080, min: 180 },
        },
    },

    // Disable third-party calls
    enableWelcomePage: true,

    // Disable STUN/TURN discovery via XMPP extdisco (mod_turncredentials not
    // installed — suppresses "service-unavailable" error spam in browser console)
    useStunTurn: false,

    // Disable analytics to avoid phone-home
    analytics: {
        disabled: true,
    },

    // Toolbar buttons
    toolbarButtons: [
        'microphone', 'camera', 'closedcaptions', 'desktop',
        'fullscreen', 'fodeviceselection', 'hangup', 'profile',
        'chat', 'settings', 'raisehand', 'videoquality', 'filmstrip',
        'tileview', 'download', 'help', 'mute-everyone', 'security',
    ],

    // Require display name before joining
    requireDisplayName: false,
};
