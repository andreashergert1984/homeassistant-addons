-- Prosody configuration for Jitsi Meet HA add-on
-- Replaces /etc/prosody/prosody.cfg.lua entirely to avoid conf.d conflicts

admins = { "focus@auth.${XMPP_DOMAIN}" }

-- Global modules (standard set that ships with Debian Prosody package)
modules_enabled = {
    "roster"; "saslauth"; "tls"; "dialback"; "disco";
    "posix"; "private"; "vcard"; "version"; "uptime";
    "time"; "ping"; "pep"; "register";
    "admin_adhoc";
}

modules_disabled = {}

-- Paths
data_path = "/data/prosody"
log = { info = "/data/logs/prosody.log" }

-- HTTP server for BOSH and WebSocket — MUST be explicit or mod_bosh won't bind
http_ports = { 5280 }
http_interfaces = { "*" }
https_ports = {}

-- TLS: terminated upstream by Nginx Proxy Manager — treat all internal
-- BOSH/WebSocket traffic as already secure, do not require STARTTLS
consider_bosh_secure = true
consider_websocket_secure = true
cross_domain_bosh = true
cross_domain_websocket = true

-- Main virtual host
VirtualHost "${XMPP_DOMAIN}"
    authentication = "${XMPP_AUTH}"
    ssl = { key = "/data/prosody/certs/${XMPP_DOMAIN}.key", certificate = "/data/prosody/certs/${XMPP_DOMAIN}.crt" }
    c2s_require_encryption = false
    consider_bosh_secure = true
    consider_websocket_secure = true
    modules_enabled = {
        "bosh"; "websocket"; "ping";
    }

${GUEST_VHOST_BLOCK}

-- Jicofo authenticates here
Component "focus.${XMPP_DOMAIN}" "client"
    authentication = "internal_plain"

-- JVB component
Component "jvb.${XMPP_DOMAIN}"
    component_secret = "${JVB_SECRET}"

-- Conference MUC (keep modules list empty — jitsi MUC plugins may not be installed)
Component "conference.${XMPP_DOMAIN}" "muc"
    storage = "memory"

-- Internal MUC for JVB brewery
Component "internal.auth.${XMPP_DOMAIN}" "muc"
    storage = "memory"
    admins = { "focus@auth.${XMPP_DOMAIN}", "jvb@auth.${XMPP_DOMAIN}" }
    restrict_room_creation = true

-- Auth virtual host for focus + jvb internal accounts
VirtualHost "auth.${XMPP_DOMAIN}"
    ssl = { key = "/data/prosody/certs/auth.${XMPP_DOMAIN}.key", certificate = "/data/prosody/certs/auth.${XMPP_DOMAIN}.crt" }
    authentication = "internal_plain"
    c2s_require_encryption = false
