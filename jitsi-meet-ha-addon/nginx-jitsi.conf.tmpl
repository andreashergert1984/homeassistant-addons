server {
    listen 80;
    server_name _;

    root /usr/share/jitsi-meet;
    index index.html;

    # Required: Jitsi's index.html uses SSI (<!--#include virtual="head.html"-->)
    # to inject config.js, interface_config.js, utils.js, do_external_connect.js
    ssi on;
    ssi_types application/x-javascript application/javascript;

    # BOSH — XMPP over HTTP
    location = /http-bind {
        proxy_pass http://127.0.0.1:5280/http-bind;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header Host $host;
        proxy_buffering off;
        proxy_read_timeout 90s;
    }

    # XMPP WebSocket
    location = /xmpp-websocket {
        proxy_pass http://127.0.0.1:5280/xmpp-websocket;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 900s;
    }

    # JVB WebSocket (Colibri)
    location ~ ^/colibri-ws/(.*) {
        proxy_pass http://127.0.0.1:9090/colibri-ws/$1$is_args$args;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 900s;
    }

    location ~ ^/([^/?&:'"]+)$ {
        try_files $uri @root_path;
    }

    location @root_path {
        rewrite ^/(.*)$ / break;
    }

    location / {
        try_files $uri $uri/ @root_path;
    }
}
